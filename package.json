{
  "name": "@mechurao/logger",
  "version": "1.2.2",
  "description": "Lightweight structured logger with colorized output",
  "author": "Ondřej Mechura <your-email@example.com>",
  "license": "MIT",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=12"
  },
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "build": "tsup src/index.ts",
    "prepare": "npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "tsup": "8.3.5",
    "typescript": "^5.0.0",
    "rimraf": "^3.0.2"
  }
}