{
  "name": "@mechurao/logger",
  "version": "1.5.0",
  "description": "Lightweight structured logger with colorized output",
  "author": "Ondřej Mechura <mechurao1998@gmail.com>",
  "license": "MIT",
  "type": "commonjs",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=14.16"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "check": "publint && attw --pack .",
    "prepare": "npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@types/node": "^24.10.1",
    "publint": "^0.3.21",
    "rimraf": "^6.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
