{
  "name": "@mechurao/logger",
  "version": "1.3.0",
  "description": "Lightweight structured logger with colorized output",
  "author": "Ondřej Mechura <mechurao1998@gmail.com>",
  "license": "MIT",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs.js",
      "import": "./dist/index.esm.js",
      "default": "./dist/index.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup src/index.ts",
    "prepare": "npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "rimraf": "^3.0.2",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0"
  }
}
